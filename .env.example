# Supabase (apps/web)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key (server-only). Required for admin "Team access" (add/remove admins). Get from Project Settings → API.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Backend URL for Next.js API routes (apps/web)
BRAIN_URL=http://127.0.0.1:3001

# Postgres for Fly backend (apps/brain)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Optional: app origin for redirects
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (for app-sent emails; auth emails use Resend via Supabase SMTP)
# RESEND_API_KEY=re_xxxx
