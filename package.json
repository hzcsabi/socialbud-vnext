{
  "name": "socialbud-vnext",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "dev:web": "pnpm --filter @socialbud/web run dev",
    "dev:web:3001": "pnpm --filter @socialbud/web run dev:port",
    "dev:brain": "pnpm --filter @socialbud/brain run dev",
    "db:migrate": "pnpm --filter @socialbud/brain run migrate",
    "lint": "pnpm -r run lint"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "@swc/core",
      "pg"
    ]
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "next": "^15.0.3",
    "tailwindcss-animate": "^1.0.7"
  }
}
