{
  "name": "socialbud-vnext",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev --parallel",
    "dev:web": "pnpm --filter @socialbud/web run dev",
    "dev:brain": "pnpm --filter @socialbud/brain run dev",
    "db:migrate": "pnpm --filter @socialbud/brain run migrate",
    "lint": "pnpm -r run lint"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.14.2",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "next": "^15.0.3",
    "tailwindcss-animate": "^1.0.7"
  }
}
